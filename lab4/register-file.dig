    <visualElement>
      <elementName>Testcase</elementName>
      <elementAttributes>
        <entry>
          <string>Label</string>
          <string>Register File Test</string>
        </entry>
        <entry>
          <string>Testdata</string>
          <testData>
            <dataString>WriteReg WriteData RegWrite Clock ReadReg1 ReadReg2 ReadData1 ReadData2

# $1 = 25
1 25 1 C 1 0 25 0

# $2 = 30
2 30 1 C 0 2 0 30

# $(N+1) = (N+1)
loop(N, 30)
	(N+1) (N+1) 1 C (N+1) (N) (N+1) (N)
end loop

# $(N+1) = N-60
loop(N, 30)
	(N+1) (N-60) 1 C (N+1) (N+1) (N-60) (N-60)
end loop

# Try writing to $0. This should not write anything
0 25 1 C 0 0 0 0

# try writing when RegWrite = 0
# (the registers should still have their old values)
loop(N, 30)
	(N+1) (N+80) 0 C (N+1) (N+1) (N-60) (N-60)
end loop</dataString>
          </testData>
        </entry>
      </elementAttributes>
      <pos x="160" y="-300"/>
